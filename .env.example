# Intercom Matrix — environment configuration.
#
# The server reads these directly from the process environment (no dotenv
# autoload). Set them in your shell, Docker/compose `environment:`, or systemd
# unit. Copy to wherever your deployment sources env from; never commit secrets.

# --- Core --------------------------------------------------------------------
PORT=8080
# Server-side auto-refresh per system, seconds (0 = off).
REFRESH_SEC=0
# RRCS live-polling SEED for first run. Once settings.json exists, the Settings
# panel's Safety toggle is authoritative. 1/true/on/yes to enable.
RRCS_ENABLED=off
# First-run setup wizard. On a fresh install (no admin, no configured system)
# the app opens a guided wizard that creates the first admin WITHOUT a prior
# login, then self-locks the moment an admin exists. Set ONBOARDING_OPEN=0 to
# disable that open path and require the LOCAL_ADMIN_* bootstrap admin instead
# (e.g. on an untrusted network). Default on.
# ONBOARDING_OPEN=1
# Paths (defaults shown). systems.json + settings.json are gitignored.
# SYSTEMS_FILE=./systems.json
# SETTINGS_FILE=./settings.json
# AUTH_DB=./data/auth.db

# --- Authentication ----------------------------------------------------------
# Login is OPTIONAL by default (anonymous = read-only). Flip "Require login" in
# Settings → Safety to gate the whole app. Roles: viewer | editor | admin
# (admin manages deployment settings, systems, and user accounts).

# At-rest encryption key for secrets configured in-app (LDAP bind password, SAML
# SP private key). 32 bytes, base64. If unset, one is generated at
# data/.secret-key (0600) on first run. Setting it here in the environment is
# stronger (key kept separate from the on-disk ciphertext). Back it up — losing
# it orphans in-app secrets (re-enter them in Settings → Users). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMX_SECRET_KEY=

# NOTE: LDAP & SAML below can be configured entirely IN-APP (Settings → Users →
# Configure…), with secrets encrypted at rest. The env vars below are a FALLBACK
# / seed; any field set in-app overrides its env value. Cert/key *_FILE paths are
# read when no in-app PEM is pasted.

# Bootstrap admin — a way in before any accounts exist. Leave PASS blank to
# disable this path once you've created real admin accounts.
LOCAL_ADMIN_USER=admin
LOCAL_ADMIN_PASS=

# Session cookie lifetime (seconds; default 90 days) and Secure flag. Set
# COOKIE_SECURE=1 when behind a TLS-terminating reverse proxy (req.secure won't
# be seen because we intentionally don't trust proxy headers — see server.js).
# SESSION_TTL=7776000
# COOKIE_SECURE=1
# Login attempts per IP per 15 min before 429.
# LOGIN_RATE_LIMIT_MAX=10

# --- LDAP / Active Directory -------------------------------------------------
# Leave LDAP_URL blank to disable. When set, it seeds the Settings → Users "LDAP"
# switch on (the switch is authoritative thereafter).
LDAP_URL=
LDAP_BASE_DN=dc=company,dc=com
# Optional narrower user search scope (falls back to LDAP_BASE_DN).
LDAP_USER_SEARCH_BASE=
# Service account for the search step (anonymous bind tried if blank).
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={{username}})
# Map directory groups → app roles. If none are set, every authenticated
# directory user is a viewer.
LDAP_GROUP_ADMIN=
LDAP_GROUP_EDITOR=
LDAP_GROUP_VIEWER=
# TLS: verify on by default. LDAP_STARTTLS=1 to upgrade a plaintext ldap://.
# Provide a CA bundle for private directories, or pin by SHA256 fingerprint.
LDAP_TLS_VERIFY=1
LDAP_STARTTLS=0
LDAP_TLS_CA_FILE=
# LDAP_TLS_FINGERPRINT_SHA256=

# --- SAML 2.0 single sign-on -------------------------------------------------
# Configure the four required fields below + the IdP cert. SAML_ENABLED seeds the
# Settings → Users "SAML" switch on first run; after that the switch is
# authoritative (turn it on/off in the admin window without a redeploy).
SAML_ENABLED=0
SAML_ENTRY_POINT=
SAML_ISSUER=intercom-matrix
SAML_CALLBACK_URL=
SAML_IDP_CERT_FILE=
# Optional SP signing key/cert (for signed AuthnRequests + metadata).
SAML_SP_PRIVATE_KEY_FILE=
SAML_SP_CERT_FILE=
SAML_WANT_ASSERTIONS_SIGNED=1
SAML_WANT_AUTHN_RESPONSE_SIGNED=1
SAML_SIGNATURE_ALGORITHM=sha256
SAML_NAME_ID_FORMAT=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
# Optional attribute overrides + group→role mapping (like LDAP_GROUP_*).
SAML_USERNAME_ATTRIBUTE=
SAML_DISPLAY_NAME_ATTRIBUTE=
SAML_GROUPS_ATTRIBUTE=
SAML_GROUP_ADMIN=
SAML_GROUP_EDITOR=
SAML_GROUP_VIEWER=
SAML_LOGOUT_URL=
