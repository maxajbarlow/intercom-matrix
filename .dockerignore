# Dependencies — reinstalled in the image via `npm ci`
node_modules/

# Local config: holds controller IPs. NEVER bake into the image; mount at runtime.
systems.json

# Runtime/local state — re-derivable or machine-local; mount as volumes instead.
data/
prints/*
!prints/README.md
topology/*
!topology/README.md

# controller config snapshots (never ship production config)
*.ash
*.Art
*.art

# Vendored Windows poppler binaries — the Linux image installs poppler-utils
# via apt (see Dockerfile), so these ~24MB of .exe/.dll are dead weight here.
vendor/poppler/win-x64/

# VCS / tooling / scratch
.git/
.gitignore
*.log
.playwright-mcp/
*.png
README.md
Dockerfile
.dockerignore
